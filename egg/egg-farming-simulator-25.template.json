                   "stop":  "^C"
               },
    "scripts":  {
                    "installation":  {
                                         "script":  "#!/bin/bash\nset -euo pipefail\n\nmkdir -p /mnt/server/installer \\\n         /mnt/server/dlc \\\n         /mnt/server/game \\\n         /mnt/server/config \\\n         /mnt/server/setup-logs\n\ncat \u003e /mnt/server/UPLOAD_INSTALLER_HERE.txt \u003c\u003c\u0027EOF\u0027\nFARMING SIMULATOR 25 SERVER SETUP\n=================================\n\n1. Download the Windows ESD installer from your GIANTS account.\n2. Upload the .img installer into the /installer folder.\n3. Start the server with AUTO_INSTALL=true and AUTOSTART_SERVER=false.\n4. Open the noVNC allocation (default port 6080) in a browser.\n5. Complete installation and activate the separate dedicated-server license.\n6. Restart the server and set AUTOSTART_SERVER=true.\n\nThe Steam edition is not supported by this image\u0027s installation flow.\nNo game or license files are downloaded by this egg.\nEOF\n\necho \"FS25 folder structure created successfully.\"\n",
                                         "container":  "ghcr.io/pelican-eggs/installers:debian",
                                         "entrypoint":  "bash"
                                     }
                },
